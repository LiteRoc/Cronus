// tsconfig.json

{
  "files": [],
  "references": [
    { "path": "./tsconfig.app.json" },
    { "path": "./tsconfig.node.json" }
  ],
  "compilerOptions": {
    "composite": true,
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "strict": true,
    "skipLibCheck": true,
    "types": ["react", "react-dom", "react-to-print"],
    "typeRoots": ["node_modules/@types"],
    //"include": ["src/**/**"],
    "moduleResolution": "node"
  }
}
