# Ignore node_modules from both frontend and backend
frontend/node_modules/
backend/node_modules/

# Ignore environment files
frontend/.env
backend/.env
.env
.env.*

# Ignore build/dist folders
frontend/dist/
backend/dist/
build/

# OS-specific junk
.DS_Store
Thumbs.db

# Log files
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# VSCode or JetBrains settings (optional)
.vscode/
.idea/

# Docker volumes if generated locally
mongo-data/

# Misc
*.env.local
*.local

# Local database backups
cronus-backup*/
*-backup*/
backups/
*.bson
*.metadata.json
