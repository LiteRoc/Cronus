<!DOCTYPE html>
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Asset Management</title>
    <link rel="stylesheet" href="/styles.css"> <!-- Optional for styling -->
    <style>
        body {
            font-family: Arial, sans-serif;
            margin: 20px;
        }
        table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 20px;
        }
        table, th, td {
            border: 1px solid #ccc;
        }
        th, td {
            padding: 8px;
            text-align: left;
        }
        th {
            background-color: #f4f4f4;
        }
        .form-container {
            margin-bottom: 20px;
        }
        .form-container label {
            display: block;
            margin-bottom: 5px;
        }
        .form-container input, .form-container button {
            margin-bottom: 10px;
            padding: 8px;
            width: 100%;
            box-sizing: border-box;
        }
        .form-container button {
            background-color: #007bff;
            color: white;
            border: none;
            cursor: pointer;
        }
        .form-container button:hover {
            background-color: #0056b3;
        }
    </style>
</head>

    <h1>Asset Management</h1>
    <!-- Search & Filter Form -->
    <form id="searchForm">
        <input type="text" id="searchInput" placeholder="Search Assets" />
        <select id="manufacturerFilter">
            <option value="">All Manufacturers</option>
            <option value="GE Healthcare">GE Healthcare</option>
            <option value="Medtronic">Medtronic</option>
            <option value="Philips">Philips</option>
            <option value="Canon Medical">Canon Medical</option>
        </select>
        <select id="statusFilter">
            <option value="">All Statuses</option>
            <option value="Active">Active</option>
            <option value="Inactive">Inactive</option>
        </select>
        <button type="submit">Search</button>
    </form>
    <!-- Asset Table -->
    <table>
        <thead>
            <tr>
                <th>ID</th>
                <th>Control Number</th>
                <th>Manufacturer</th>
                <th>Model</th>
                <th>Serial Number</th>
                <th>Status</th>
                <th>Notes</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
            <% assets.forEach(asset => { %>
            <tr>
                <td><%= asset._id %></td>
                <td><%= asset.ctrlNumber %></td>
                <td><%= asset.manufacturer %></td>
                <td><%= asset.model %></td>
                <td><%= asset.serialNumber %></td>
                <td><%= asset.status %></td>
                <td><%= asset.notes || '' %></td>
                <td>
                    <button onclick="editAsset('<%= asset._id %>')">Edit</button>
                    <button onclick="deleteAsset('<%= asset._id %>')">Delete</button>
                    <td>
                        <a href="/assets/<%= asset._id %>/workorders">
                            <button>View Work Orders</button>
                        </a>
                    </td>
                    
                </td>
            </tr>
            <% }); %>
        </tbody>
    </table>

    <!-- Form to Add/Edit Asset -->
    <div class="form-container">
        <h2>Add / Edit Asset</h2>
        <form id="assetForm">
            <label for="id">ID</label>
            <input type="text" id="id" name="id" disabled>
            <label for="ctrlNumber">Control Number</label>
            <input type="text" id="ctrlNumber" name="ctrlNumber" required>
            <label for="manufacturer">Manufacturer</label>
            <input type="text" id="manufacturer" name="manufacturer" required>
            <label for="model">Model</label>
            <input type="text" id="model" name="model" required>
            <label for="serialNumber">Serial Number</label>
            <input type="text" id="serialNumber" name="serialNumber" required>
            <label for="status">Status</label>
            <input type="text" id="status" name="status" required>
            <label for="notes">Notes</label>
            <input type="text" id="notes" name="notes">
            <button type="submit">Save Asset</button>
        </form>
    </div>

    <script>
        async function fetchAssets() {
            const response = await fetch('/assets');
            const data = await response.json();
            console.log(data);
        }
        
        // Populate the form with the work order information
        function editAsset(assetId) {
            fetch(`/assets/${assetId}`)
                .then((response) => {
                    if (!response.ok) {
                        throw new Error(`Error fetching asset: ${response.statusText}`);
                    }
                    return response.json();
                })
                .then((asset) => {
                    // Populate the form fields with fetched asset data
                    document.getElementById('id').value = asset._id; // Ensure 'assetId' exists in your form .. needs to be id
                    document.getElementById('ctrlNumber').value = asset.ctrlNumber; // Ensure these IDs match your form fields
                    document.getElementById('manufacturer').value = asset.manufacturer;
                    document.getElementById('model').value = asset.model;
                    document.getElementById('serialNumber').value = asset.serialNumber;
                    document.getElementById('status').value = asset.status;
                    document.getElementById('notes').value = asset.notes || ''; // Use empty string if notes are null
                })
                .catch((error) => {
                    console.error('Error fetching asset details:', error);
                    alert('Failed to fetch asset details.');
                });
        }

        async function deleteAsset(id) {
            const response = await fetch(`/assets/${id}`, { method: 'DELETE' });
            if (response.ok) {
                alert('Asset deleted successfully');
                window.location.reload();
            } else {
                alert('Error deleting asset');
            }
        }

        document.getElementById('searchForm').addEventListener('submit', async (event) => {
            event.preventDefault();

            const search = document.getElementById('searchInput').value;
            const manufacturer = document.getElementById('manufacturerFilter').value;
            const status = document.getElementById('statusFilter').value;

            // Fetch filtered assets from the backend
            const response = await fetch(`/assets?search=${encodeURIComponent(search)}&manufacturer=${encodeURIComponent(manufacturer)}&status=${encodeURIComponent(status)}`);
            const assets = await response.json();

            // Update the table with the new data
            const tableBody = document.querySelector('#assetsTable tbody');
            tableBody.innerHTML = ''; // Clear existing rows

            assets.forEach(asset => {
                const row = `
                    <tr>
                        <td>${asset.ctrlNumber}</td>
                        <td>${asset.manufacturer}</td>
                        <td>${asset.model}</td>
                        <td>${asset.serialNumber}</td>
                        <td>${asset.status}</td>
                        <td>${asset.notes}</td>
                    </tr>
                `;
                tableBody.innerHTML += row;
            });
        });


        async function viewWorkOrders(assetId) {
            const response = await fetch(`/api/assets/${assetId}/workorders`);
            const workOrders = await response.json();

            console.log(workOrders); // Replace with code to render work orders in the UI
        }
        

        document.getElementById('searchForm').addEventListener('submit', async (event) => {
        event.preventDefault();

        const search = document.getElementById('searchInput').value;
        const manufacturer = document.getElementById('manufacturerFilter').value;
        const status = document.getElementById('statusFilter').value;

        const response = await fetch(`/assets?search=${search}&manufacturer=${manufacturer}&status=${status}`);
        const assets = await response.json();

        const tableBody = document.querySelector('#assetsTable tbody');
        tableBody.innerHTML = ''; // Clear previous results

        assets.forEach(asset => {
            const row = `
                <tr>
                    <td>${asset.ctrlNumber}</td>
                    <td>${asset.manufacturer}</td>
                    <td>${asset.model}</td>
                    <td>${asset.serialNumber}</td>
                    <td>${asset.status}</td>
                </tr>
            `;
            tableBody.innerHTML += row;
        });
    });

        document.getElementById("assetForm").addEventListener("submit", async (e) => {
            e.preventDefault();
        });
    </script>
