<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
</head>
<body>
    <h1>Welcome to your Dashboard, <%= user.username %>!</h1>
    <p>Email: <%= user.email %></p>
    <p>Role: <%= user.role %></p>
    <a href="/auth/login" onclick="logout()">Logout</a>

    <script>
        // Check if token exists and fetch dashboard data
        const token = localStorage.getItem('token'); // Retrieve the token from localStorage
        if (!token) {
            alert('You are not logged in!');
            window.location.href = '/auth/login'; // Redirect to login page
        } else {
            // fetch data using the token
            fetch('/dashboard', {
                method: 'GET',
                headers: { 
                    'Authorization': `Bearer ${token}`, // Add the JWT token in the header
                    'Content-Type': 'application/json', // Optional for GET requests
                },
            })
                .then(response => {
                    if (!response.ok) {
                        throw new Error('Failed to fetch dashboard content');
                    }
                    return response.json();
                })
                .then(data => {
                    console.log('Dashboard data:', data); // Debug the received data
                    document.getElementById('dashboardContent').innerText = `Hello, ${data.username}! Role: ${data.role}`;
                })
                .catch(error => {
                    console.error('Error:', error);
                    alert('Session expired. Please log in again.');
                    localStorage.removeItem('token');
                    window.location.href = '/auth/login';
                });
        }
        function logout() {
            localStorage.removeItem('token'); // Clear the token
            alert('You have been logged out.');
        }
    </script>
</body>
</html>
